# Latest / floating tags for local development.
# Optional — `docker compose up` uses the same defaults without this file.
# Use: docker compose --env-file docker/versions.dev.env up --build

POSTGRES_IMAGE=postgres:latest
REDIS_IMAGE=redis:alpine
AZURITE_IMAGE=mcr.microsoft.com/azure-storage/azurite:latest
PROMETHEUS_IMAGE=prom/prometheus:latest
POSTGRES_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter:latest
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:latest
GRAFANA_IMAGE=grafana/grafana:latest

DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:latest
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:latest
NODE_IMAGE=node:bookworm-slim
NGINX_IMAGE=nginx:alpine
RUST_IMAGE=rust:bookworm
DEBIAN_IMAGE=debian:bookworm-slim
