# Pinned container versions for CI, deployment, and prod-like local runs.
# Use: docker compose --env-file docker/versions.prod.env up --build
# Scripts set COMPOSE_ENV_FILE=docker/versions.prod.env when CI parity is required.

# Infrastructure (Compose services)
POSTGRES_IMAGE=postgres:18.4
REDIS_IMAGE=redis:8.8.0-alpine
AZURITE_IMAGE=mcr.microsoft.com/azure-storage/azurite:3.35.0
PROMETHEUS_IMAGE=prom/prometheus:v3.12.0
POSTGRES_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter:v0.19.1
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:v1.86.0
GRAFANA_IMAGE=grafana/grafana:13.0.2

# Application build bases (Docker build-args)
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0
DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0
NODE_IMAGE=node:26.3-bookworm-slim
NGINX_IMAGE=nginx:1.31.1-alpine
RUST_IMAGE=rust:1.96.0-bookworm
DEBIAN_IMAGE=debian:bookworm-slim
