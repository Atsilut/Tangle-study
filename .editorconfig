root = true

[*.cs]
# Braces on multi-line single-statement guards hurt readability for simple actions
dotnet_diagnostic.RCS1001.severity = none
dotnet_diagnostic.RCS1003.severity = none
# EF and domain entities use { get; private set; } instead of { get; } for mapped properties
dotnet_diagnostic.RCS1170.severity = none
# Trailing whitespace
dotnet_diagnostic.RCS1037.severity = none

[services/Api/Migrations/**.cs]
generated_code = true
dotnet_analyzer_diagnostic.category-roslynator.severity = none
