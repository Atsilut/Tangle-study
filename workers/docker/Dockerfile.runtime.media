# syntax=docker/dockerfile:1
# Runtime image — requires scripts/ci/build-workers-release.sh (workers/target/release/worker-media)

ARG DEBIAN_IMAGE=debian:bookworm-slim

FROM ${DEBIAN_IMAGE}
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates ffmpeg \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
EXPOSE 9090
COPY workers/target/release/worker-media /app/worker-media
ENTRYPOINT ["/app/worker-media"]
