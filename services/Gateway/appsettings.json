{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Secret": "dev-gateway-secret"
  },
  "ReverseProxy": {
    "Routes": {
      "chat-group-rooms": {
        "ClusterId": "chat",
        "Order": 0,
        "Match": { "Path": "/api/groups/{groupId}/chat-rooms/{**remainder}" }
      },
      "community-board-posts": {
        "ClusterId": "community",
        "Order": 0,
        "Match": { "Path": "/api/groups/{groupId}/boards/{boardId}/posts/{**remainder}" }
      },
      "social-blocks-exact": {
        "ClusterId": "social",
        "Order": 0,
        "Match": { "Path": "/api/users/blocks" }
      },
      "social-blocks": {
        "ClusterId": "social",
        "Order": 0,
        "Match": { "Path": "/api/users/blocks/{**remainder}" }
      },
      "users-login": {
        "ClusterId": "users",
        "Order": 1,
        "Match": { "Path": "/api/login" }
      },
      "users-join-exact": {
        "ClusterId": "users",
        "Order": 1,
        "Match": { "Path": "/api/join" }
      },
      "users-join": {
        "ClusterId": "users",
        "Order": 1,
        "Match": { "Path": "/api/join/{**remainder}" }
      },
      "users-list": {
        "ClusterId": "users",
        "Order": 1,
        "Match": { "Path": "/api/users" }
      },
      "users-by-id": {
        "ClusterId": "users",
        "Order": 1,
        "Match": { "Path": "/api/users/{userId:long}" }
      },
      "users-api": {
        "ClusterId": "users",
        "Order": 2,
        "Match": { "Path": "/api/users/{**remainder}" }
      },
      "media-api": {
        "ClusterId": "media",
        "Order": 1,
        "Match": { "Path": "/api/media/{**remainder}" }
      },
      "chat-api": {
        "ClusterId": "chat",
        "Order": 1,
        "Match": { "Path": "/api/chat/{**remainder}" }
      },
      "chat-hubs-exact": {
        "ClusterId": "chat",
        "Order": 1,
        "Match": { "Path": "/hubs/chat" }
      },
      "chat-hubs": {
        "ClusterId": "chat",
        "Order": 1,
        "Match": { "Path": "/hubs/chat/{**remainder}" }
      },
      "location-api": {
        "ClusterId": "location",
        "Order": 1,
        "Match": { "Path": "/api/location/{**remainder}" }
      },
      "location-hubs-exact": {
        "ClusterId": "location",
        "Order": 1,
        "Match": { "Path": "/hubs/location" }
      },
      "location-hubs": {
        "ClusterId": "location",
        "Order": 1,
        "Match": { "Path": "/hubs/location/{**remainder}" }
      },
      "community-posts": {
        "ClusterId": "community",
        "Order": 1,
        "Match": { "Path": "/api/posts/{**remainder}" }
      },
      "community-comments": {
        "ClusterId": "community",
        "Order": 1,
        "Match": { "Path": "/api/comments/{**remainder}" }
      },
      "group-api": {
        "ClusterId": "group",
        "Order": 2,
        "Match": { "Path": "/api/groups/{**remainder}" }
      },
      "group-invitations": {
        "ClusterId": "group",
        "Order": 1,
        "Match": { "Path": "/api/invitations/{**remainder}" }
      },
      "group-applications": {
        "ClusterId": "group",
        "Order": 1,
        "Match": { "Path": "/api/applications/{**remainder}" }
      },
      "social-friendships": {
        "ClusterId": "social",
        "Order": 1,
        "Match": { "Path": "/api/friendships/{**remainder}" }
      }
    },
    "Clusters": {
      "users": {
        "Destinations": {
          "d1": { "Address": "http://users:8080/" }
        }
      },
      "media": {
        "Destinations": {
          "d1": { "Address": "http://media:8080/" }
        }
      },
      "chat": {
        "Destinations": {
          "d1": { "Address": "http://chat:8080/" }
        }
      },
      "location": {
        "Destinations": {
          "d1": { "Address": "http://location:8080/" }
        }
      },
      "community": {
        "Destinations": {
          "d1": { "Address": "http://community:8080/" }
        }
      },
      "group": {
        "Destinations": {
          "d1": { "Address": "http://group:8080/" }
        }
      },
      "social": {
        "Destinations": {
          "d1": { "Address": "http://social:8080/" }
        }
      }
    }
  }
}
